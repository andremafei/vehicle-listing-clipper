{
  "name": "vehicle-listing-clipper",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "description": "Tampermonkey userscript: local OLX/Standvirtual listing clipper plus CRM lead verify/create on crm.flexicar.pt",
  "scripts": {
    "dev": "node dev/server.mjs",
    "build": "node scripts/build-production.mjs && node scripts/build-local-loader.mjs",
    "build:dev": "vite build --mode development --config vite.config.js",
    "build:prod": "node scripts/build-production.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "release:check": "node scripts/release-check.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.1"
  },
  "dependencies": {
    "onnxruntime-web": "^1.22.0"
  }
}
